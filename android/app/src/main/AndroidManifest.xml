<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- ===== PERMISSIONS ===== -->

    <!-- Izin wajib untuk floating window di atas aplikasi lain (SYSTEM_ALERT_WINDOW) -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW"/>

    <!-- Izin internet untuk API calls ke Gemini / OpenAI -->
    <uses-permission android:name="android.permission.INTERNET"/>

    <!-- Izin rekam audio untuk fitur voice input -->
    <uses-permission android:name="android.permission.RECORD_AUDIO"/>

    <!-- Izin vibrate untuk haptic feedback -->
    <uses-permission android:name="android.permission.VIBRATE"/>

    <!-- Izin foreground service agar overlay tetap aktif saat app di-minimize -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE"/>

    <!-- Android 14+ (API 34): wajib deklarasikan tipe foreground service -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE"/>

    <!-- Android 13+ (API 33): izin tampilkan notifikasi untuk overlay service -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS"/>

    <!-- Izin baca media gambar (untuk fitur screenshot/OCR) -->
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES"/>

    <application
        android:label="AI Floating Assistant"
        android:name="${applicationName}"
        android:icon="@mipmap/ic_launcher"
        android:allowBackup="true"
        android:enableOnBackInvokedCallback="true">

        <!-- ===== MAIN ACTIVITY ===== -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize">

            <meta-data
                android:name="io.flutter.embedding.android.NormalTheme"
                android:resource="@style/NormalTheme"/>

            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>

        <!-- ===== OVERLAY SERVICE =====
             Service milik plugin flutter_overlay_window yang menjalankan
             Flutter engine kedua untuk floating bubble.

             CATATAN PENTING:
             - android:exported="false"  → service tidak bisa diakses app lain
             - foregroundServiceType     → wajib untuk Android 14+ (API 34)
             - Jika targetSdk < 34, baris foregroundServiceType bisa dihapus
        -->
<service
            android:name="flutter.overlay.window.flutter_overlay_window.OverlayService"
            android:exported="false"
            android:foregroundServiceType="specialUse">

            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="Floating AI assistant overlay displayed above other apps"/>

        </service>

        <!-- Meta-data Flutter embedding versi 2 -->
        <meta-data
            android:name="flutterEmbedding"
            android:value="2"/>

        <!-- Entry point untuk overlay window (dart:ui IsolateNameServer) -->
        <meta-data
            android:name="io.flutter.embedding.android.FlutterActivityLaunchConfigs"
            android:value="overlayMain" />

    </application>

    <!-- Android 11+ (API 30): deklarasikan intent yang bisa di-query -->
    <queries>
        <intent>
            <action android:name="android.intent.action.MAIN"/>
        </intent>
        <intent>
            <action android:name="android.settings.ACTION_MANAGE_OVERLAY_PERMISSION"/>
        </intent>
    </queries>

</manifest>
